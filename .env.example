PORT=5000
TENANT_ID=default

# Comma-separated browser origins for CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGO_URI=mongodb://127.0.0.1:27017/cafe-diamond-queen
JWT_SECRET=change_me_to_a_long_random_string

# Razorpay — use Test or Live keys from Dashboard → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhooks → create secret in Razorpay dashboard; raw body route verifies HMAC
RAZORPAY_WEBHOOK_SECRET=

# Only for local demos. Never enable in production.
PAYMENT_ALLOW_DEMO=false

# Gemini / Diamond AI
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Unsplash — free tier for dynamic food photography (developers.unsplash.com)
UNSPLASH_ACCESS_KEY=

# Email (SMTP): Mailtrap, SendGrid, Resend SMTP, etc.
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=
EMAIL_PASS=

# Admin insights: GET /api/insights/admin/sentiment-summary
ADMIN_API_KEY=

NODE_ENV=development
LOG_LEVEL=info
